{
  "name": "commune-backend",
  "version": "1.0.0",
  "description": "Node.js + Express + MySQL backend for the Commune events platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "mysql -u root -p < config/schema.sql",
    "db:seed": "mysql -u root -p commune_db < config/schema.sql"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "nodemailer": "^8.0.7",
    "razorpay": "^2.9.6",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
